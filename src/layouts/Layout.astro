---
import { siteConfig } from "../config/site";

type StructuredData = Record<string, unknown>;

interface Props {
    title?: string;
    description?: string;
    image?: string;
    imageAlt?: string;
    type?: "website" | "article";
    noindex?: boolean;
    keywords?: string[];
    structuredData?: StructuredData | StructuredData[];
}

const {
    title = siteConfig.defaultTitle,
    description = siteConfig.defaultDescription,
    image = siteConfig.defaultSocialImagePath,
    imageAlt = siteConfig.defaultSocialImageAlt,
    type = "website",
    noindex = false,
    keywords = siteConfig.defaultKeywords,
    structuredData = [],
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? siteConfig.siteUrl;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL(image, siteUrl).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const structuredDataItems = Array.isArray(structuredData)
    ? structuredData
    : [structuredData];
const keywordsContent = keywords.join(", ");

const baseStructuredData = [
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        name: siteConfig.siteName,
        url: siteUrl,
        email: siteConfig.supportEmail,
        logo: new URL(siteConfig.defaultSocialImagePath, siteUrl).toString(),
        sameAs: siteConfig.socialLinks.map((link) => link.href),
    },
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: siteConfig.siteName,
        url: siteUrl,
        description: siteConfig.defaultDescription,
        inLanguage: siteConfig.language,
    },
];

const allStructuredData = [...baseStructuredData, ...structuredDataItems];
const structuredDataScripts = allStructuredData.map((item) =>
    JSON.stringify(item),
);
---

<!doctype html>
<html lang="en">
    <head>
        <script
            is:inline
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-7V4ZD8VVYD"
        ></script>
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                window.dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-7V4ZD8VVYD");
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content={robotsContent} />
        <meta name="theme-color" content="#fff0df" />
        <meta name="keywords" content={keywordsContent} />
        <meta name="author" content={siteConfig.siteName} />
        <meta name="application-name" content={siteConfig.siteName} />
        <meta property="og:locale" content={siteConfig.locale} />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/images/icon.png" />

        <meta property="og:site_name" content={siteConfig.siteName} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={type} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={socialImageUrl} />
        <meta property="og:image:alt" content={imageAlt} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content={siteConfig.xHandle} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImageUrl} />
        <meta name="twitter:image:alt" content={imageAlt} />

        {
            structuredDataScripts.map((structuredDataScript) => (
                <script
                    type="application/ld+json"
                    is:inline
                    set:text={structuredDataScript}
                />
            ))
        }
    </head>
    <body>
        <div
            class="flex min-h-svh flex-col bg-orange-75 text-stone-900 dark:bg-stone-900 dark:text-orange-25"
        >
            <slot />
        </div>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
    }
</style>
