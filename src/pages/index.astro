---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import AppHeader from "../components/AppHeader.astro";
import AppFooter from "../components/AppFooter.astro";
import AppleWordmark from "../components/AppleWordmark.astro";
import MacDownloadButton from "../components/buttons/MacDownloadButton.astro";
import PurchaseButton from "../components/buttons/PurchaseButton.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import FaqsContent from "../components/faq/FaqsContent.astro";
import MacSimulator from "../components/MacSimulator";
import { siteConfig } from "../config/site";
import { featureItems } from "../config/features";
import "../assets/css/main.css";

const faqs = (await getCollection("faqs")).sort(
    (a, b) => a.data.order - b.data.order,
);
const featureList = featureItems.map(
    (feature) => `${feature.titleTop} ${feature.titleBottom}`,
);
const homepageUrl = siteConfig.siteUrl;

const structuredData = [
    {
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: siteConfig.defaultTitle,
        description: siteConfig.defaultDescription,
        url: homepageUrl,
        isPartOf: {
            "@type": "WebSite",
            name: siteConfig.siteName,
            url: homepageUrl,
        },
        about: {
            "@type": "SoftwareApplication",
            name: siteConfig.siteName,
        },
        inLanguage: siteConfig.language,
    },
    {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: siteConfig.siteName,
        applicationCategory: "MultimediaApplication",
        applicationSubCategory: "Desktop Enhancement",
        operatingSystem: "macOS 14 Sonoma or later",
        description: siteConfig.defaultDescription,
        url: homepageUrl,
        image: `${siteConfig.siteUrl}${siteConfig.defaultSocialImagePath}`,
        featureList,
        downloadUrl: new URL(siteConfig.downloadUrl, siteConfig.siteUrl).toString(),
        offers: {
            "@type": "Offer",
            price: siteConfig.priceUsd,
            priceCurrency: "USD",
            availability: "https://schema.org/InStock",
            url: siteConfig.purchaseUrl,
        },
        brand: {
            "@type": "Brand",
            name: siteConfig.siteName,
        },
        publisher: {
            "@type": "Organization",
            name: siteConfig.siteName,
            url: siteConfig.siteUrl,
        },
    },
    {
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "VibeHUD frequently asked questions",
        itemListElement: faqs.slice(0, 5).map((entry, index) => ({
            "@type": "ListItem",
            position: index + 1,
            name: entry.data.title,
            url: `${siteConfig.siteUrl}/faqs#${entry.id}`,
        })),
    },
];
---

<Layout
    title={siteConfig.defaultTitle}
    description={siteConfig.defaultDescription}
    keywords={[
        "VibeHUD for Mac",
        "Dynamic Island for macOS",
        "macOS Dynamic Island app",
        "Mac live activities app",
        "Mac media controls app",
    ]}
    structuredData={structuredData}
>
    <AppHeader />
    <main
        class="flex flex-1 justify-center px-8 pt-32 pb-16 sm:pt-48 sm:pb-28 xl:px-36"
    >
        <section class="flex w-full max-w-screen-xl flex-col items-center">
            <!-- Hero Section -->
            <section class="mb-14 w-full sm:mb-20 xl:w-4/5 xl:max-w-screen-lg">
                <h1
                    class="relative text-center mb-6 text-6xl font-bold tracking-tight sm:text-8xl animate-fade-in"
                >
                    Dynamic Island
                    <br />
                    for
                    <AppleWordmark
                        class="pl-[55px] sm:pl-21"
                        iconClass="absolute -bottom-1 -left-1 size-16 overflow-visible fill-current sm:-bottom-1.5 sm:-left-2 sm:size-25"
                    />
                </h1>

                <p class="mx-auto max-w-2xl text-center text-xl leading-relaxed text-stone-700 dark:text-orange-75/80">
                    VibeHUD is a Dynamic Island app for macOS that brings live
                    activities, media controls, notifications, and lightweight
                    widgets to your Mac with fluid native animations.
                </p>

                <!-- CTA Buttons -->
                <div
                    class="mt-14 flex flex-col items-center justify-center space-y-6 sm:mt-12 sm:flex-row sm:space-y-0 sm:space-x-7"
                >
                    <MacDownloadButton href={siteConfig.downloadUrl} />
                    <PurchaseButton
                        href={siteConfig.purchaseUrl}
                        price={siteConfig.priceLabel}
                    />
                </div>
            </section>

            <!-- Mac Simulator -->
            <MacSimulator client:visible />

            <section class="mt-10 max-w-screen-md text-center text-lg leading-relaxed text-stone-600 dark:text-orange-75/70 sm:mt-12">
                <p>
                    Built for people who want Dynamic Island style interactions on
                    Mac, VibeHUD focuses on fast media controls, glanceable status,
                    and a polished desktop HUD that stays out of the way.
                </p>
            </section>

            <!-- Features Grid -->
            <FeatureGrid />

            <!-- FAQs -->
            <section id="faqs" class="mt-20 w-full max-w-screen-md sm:mt-28">
                <FaqsContent />
            </section>
        </section>
    </main>
    <AppFooter />
</Layout>
