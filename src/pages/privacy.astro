---
import Layout from '../layouts/Layout.astro'
import AppHeader from '../components/AppHeader.astro'
import AppFooter from '../components/AppFooter.astro'
import { siteConfig } from '../config/site'
import { uiClasses } from '../config/ui'
import '../assets/css/main.css'

const pageUrl = `${siteConfig.siteUrl}/privacy`
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'VibeHUD Privacy Policy',
  description:
    'Learn how VibeHUD handles privacy on macOS. VibeHUD does not collect personal data or analytics from the app.',
  url: pageUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: siteConfig.siteName,
    url: siteConfig.siteUrl,
  },
  inLanguage: siteConfig.language,
}
---
<Layout
  title="VibeHUD Privacy Policy | Data Collection and App Privacy"
  description="Learn how VibeHUD handles privacy on macOS. VibeHUD does not collect personal data or analytics from the app."
  keywords={[
    'VibeHUD privacy policy',
    'VibeHUD data collection',
    'VibeHUD app privacy',
    'macOS app privacy policy',
  ]}
  structuredData={structuredData}
>
  <AppHeader showDownload={false} />
  <main class="flex flex-1 justify-center px-8 pt-32 pb-16 sm:pt-48 sm:pb-28 xl:px-36">
    <section class="w-full max-w-screen-md">
      <h1 class="mb-6 text-5xl font-bold tracking-tight sm:text-7xl">Privacy</h1>
      <div class="space-y-6 text-xl leading-relaxed text-stone-700 dark:text-orange-75/85">
        <p>
          VibeHUD does not collect personal data or usage analytics from inside the macOS app.
        </p>
        <p>
          The app is designed to run locally on your Mac without sending your personal content,
          playback data, or notification history to VibeHUD servers.
        </p>
        <p>
          This website may use standard web analytics to understand visits and improve the product,
          but the VibeHUD app itself does not track you.
        </p>
        <p>
          For answers about trials, refunds, licensing, or installation, visit the
          <a class:list={[uiClasses.contactLink, 'ml-1']} href="/faqs">FAQ page</a>.
        </p>
        <p>
          If you have privacy-related questions, contact
          <a
            class:list={[uiClasses.contactLink, 'ml-1']}
            href={`mailto:${siteConfig.supportEmail}?subject=VibeHUD%20Privacy`}
          >
            {siteConfig.supportEmail}
          </a>.
        </p>
      </div>
    </section>
  </main>
  <AppFooter />
</Layout>
