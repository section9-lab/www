---
import { getCollection } from 'astro:content'
import FaqAccordion from './FaqAccordion'
import FaqDocumentIcon from '../icons/FaqDocumentIcon.astro'
import { siteConfig } from '../../config/site'
import { uiClasses } from '../../config/ui'

const faqs = (await getCollection('faqs'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    id: entry.id,
    title: entry.data.title,
    badge: entry.data.badge,
    notes: entry.data.notes,
    body: entry.body ?? '',
  }))

const lastUpdated = 'April 2026'
---

<div class="mb-0 w-full max-w-screen-md sm:mb-6">
  <h1 class="mb-3 text-6xl font-bold sm:text-8xl">FAQs</h1>

  <div>
    <p class="group dark:text-orange-75/50 flex items-center text-xl text-stone-500">
      <FaqDocumentIcon class="mr-2 size-[22px] fill-current" />
      <span>Updated {lastUpdated}</span>
    </p>
  </div>

  <FaqAccordion client:idle items={faqs} />

  <div class="mt-12 pt-6">
    <h3 class="mb-3 text-2xl font-bold">Have more questions?</h3>
    <p class="text-xl">
      If you have any additional questions, do not hesitate to
      <a
        class:list={[uiClasses.contactLink, 'ml-1']}
        href={`mailto:${siteConfig.supportEmail}`}
        aria-label="Contact us"
      >
        contact us
      </a>.
    </p>
  </div>
</div>
