---
import AppleIcon from '../icons/AppleIcon.astro'
import ArrowRightIcon from '../icons/ArrowRightIcon.astro'
import { uiClasses } from '../../config/ui'

interface Props {
  href: string
  class?: string
  compact?: boolean
}

const { href, class: className = '', compact = false } = Astro.props
const rootClasses = compact
  ? ['group relative inline-flex max-h-15 items-center justify-center rounded-2xl px-5 py-4 text-lg font-bold pl-13', uiClasses.focusRing, uiClasses.softSurface]
  : ['group relative inline-flex max-h-15 items-center justify-center rounded-2xl px-5 py-4 text-lg font-bold pl-13', uiClasses.focusRing, uiClasses.primarySurface]
---
<a class:list={[rootClasses, className]} href={href} aria-label="Download for Mac">
  <div class="ease absolute left-5 translate-x-0 opacity-100 transition duration-300 group-hover:-translate-x-full group-hover:scale-x-50 group-hover:opacity-0 group-hover:blur-sm">
    <AppleIcon class="h-6 w-6 fill-current" />
  </div>
  <div class="ease translate-x-0 transition duration-300 group-hover:-translate-x-8">
    Download for Mac
  </div>
  <div class="ease absolute right-5 translate-x-full scale-x-50 opacity-0 blur-sm transition duration-300 group-hover:translate-x-0 group-hover:scale-x-100 group-hover:opacity-100 group-hover:blur-none">
    <ArrowRightIcon class="h-6 w-6 fill-transparent stroke-current stroke-2" />
  </div>
</a>
