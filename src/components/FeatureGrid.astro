---
import FeatureIllustration from "./features/FeatureIllustration.astro";
import { featureItems } from "../config/features";
---

<section class="isolate mt-16 w-full sm:mt-12">
    <h2 class="sr-only">Dyno features for Mac</h2>
    <div
        class="mx-auto grid w-full gap-x-3 gap-y-10 tracking-tight sm:max-w-screen-lg sm:grid-cols-4 sm:gap-y-14"
    >
        {
            featureItems.map((feature) => (
                <div class="group flex flex-col items-center justify-center text-center">
                    <FeatureIllustration id={feature.id} />
                    <h2 class="w-full text-3xl font-bold">
                        {feature.titleTop}
                        <br />
                        {feature.id === "blazing-fast-native-app" ? (
                            <span class="feature-pencil-mark relative inline-flex px-3 py-1">
                                <span class="relative z-10">native app</span>
                                <svg
                                    class="pointer-events-none absolute -inset-x-3 -inset-y-2 h-[calc(100%+1rem)] w-[calc(100%+1.5rem)] overflow-visible"
                                    viewBox="0 0 240 60"
                                    aria-hidden="true"
                                >
                                    <path
                                        class="feature-pencil-mark__stroke feature-pencil-mark__stroke--main"
                                        d="M18 14 C78 7, 146 8, 208 22 C223 26, 228 38, 213 46 C194 56, 166 62, 134 66 C103 70, 66 72, 31 64 C17 61, 12 52, 20 43 C28 35, 42 30, 56 28"
                                    />
                                </svg>
                            </span>
                        ) : (
                            feature.titleBottom
                        )}
                    </h2>
                </div>
            ))
        }
    </div>
</section>

<style>
    .feature-pencil-mark {
        --pencil-pink: rgba(255, 130, 170, 0.92);
    }

    .feature-pencil-mark__stroke {
        fill: none;
        stroke: var(--pencil-pink);
        stroke-linecap: round;
        stroke-linejoin: round;
        vector-effect: non-scaling-stroke;
        filter: drop-shadow(0 1px 0 rgba(255, 130, 170, 0.14));
    }

    .feature-pencil-mark__stroke--main {
        stroke-width: 4.5;
        stroke-dasharray: 430;
        stroke-dashoffset: 430;
        animation: pencil-draw-main 1s 0.35s cubic-bezier(0.22, 1, 0.36, 1)
            forwards;
    }

    .feature-pencil-mark__stroke--accent {
        stroke-width: 5;
        stroke-dasharray: 120;
        stroke-dashoffset: 120;
        animation: pencil-draw-accent 0.45s 1.1s cubic-bezier(0.22, 1, 0.36, 1)
            forwards;
    }

    @keyframes pencil-draw-main {
        to {
            stroke-dashoffset: 0;
        }
    }

    @keyframes pencil-draw-accent {
        to {
            stroke-dashoffset: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .feature-pencil-mark__stroke--main,
        .feature-pencil-mark__stroke--accent {
            animation: none;
            stroke-dashoffset: 0;
        }
    }
</style>
